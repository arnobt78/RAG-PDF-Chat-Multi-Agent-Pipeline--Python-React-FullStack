# RAG PDF Chat Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Primary API Key (OpenRouter - Recommended)
# =============================================================================
# OpenRouter provides access to multiple models through a single API
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your_openrouter_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# =============================================================================
# Fallback Providers (Optional — each key you add unlocks that provider)
# =============================================================================
# Groq — fast inference on LPU hardware
# Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_groq_key_here

# Direct OpenAI API
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_DIRECT_API_KEY=sk-your_openai_key_here

# Google Gemini
# Get your key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_gemini_key_here

# Hugging Face Inference
# Get your key at: https://huggingface.co/settings/tokens
# HF_API_KEY=hf_your_token_here

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_PROVIDER=openrouter

# LLM Settings
TEMPERATURE=0.0
MAX_TOKENS=2048

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4

# FAISS index persistence directory (relative to backend/)
FAISS_PERSIST_DIR=faiss_index

# =============================================================================
# Sentry (optional — document DSN for ops; tunnel POST /api/oversight needs no secret)
# =============================================================================
# SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456
# SENTRY_ENVIRONMENT=production

# =============================================================================
# CORS (comma-separated browser origins that may call the API)
# =============================================================================
# Local Vite + Vercel production + preview (replace with your real URLs):
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app,https://your-app-git-main.vercel.app
# If unset, defaults to localhost:5173 / :3000 only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =============================================================================
# Debug Mode (set to true for development)
# =============================================================================
DEBUG=false
