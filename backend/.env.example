# RAG PDF Chat Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Primary API Key (OpenRouter - Recommended)
# =============================================================================
# OpenRouter provides access to multiple models through a single API
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your_openrouter_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# =============================================================================
# Alternative Providers (Optional)
# =============================================================================
# Direct OpenAI API (if not using OpenRouter)
# OPENAI_DIRECT_API_KEY=sk-your_openai_key_here

# Groq API for fast inference
# Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_groq_key_here

# =============================================================================
# Application Settings
# =============================================================================
# Default model to use
DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_PROVIDER=openrouter

# LLM Settings
TEMPERATURE=0.0
MAX_TOKENS=2048

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4

# =============================================================================
# CORS Settings (comma-separated list)
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Debug Mode (set to true for development)
# =============================================================================
DEBUG=false
